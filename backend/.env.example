# 后端程序平时连接 MySQL 使用的普通数据库账号。
# 生产环境不要让后端直接使用 root 账号。
DB_USER=dwc
DB_PASSWORD=dwc@123
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=devices_web_control

# 初始化数据库时使用的 MySQL 管理员账号。
# 仅用于创建数据库、创建 dwc 用户、授权等初始化操作。
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=123456

# 室内巡检无人车管理平台的默认登录账号。
# 这是前端登录页面输入的系统账号，不是 MySQL 账号。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456
ADMIN_NICKNAME=system-admin

# JWT 登录令牌配置。
# SECRET_KEY 用于签名 Token，生产环境请换成更长、更随机的密钥。
JWT_SECRET_KEY=dwc-super-secret-key-for-jwt-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Nano 常驻 vehicle_agent 服务配置。
VEHICLE_AGENT_BASE_URL=http://192.168.31.139:9000
VEHICLE_CAMERA_STREAM_URL=http://192.168.31.139:8080/
VEHICLE_REQUEST_TIMEOUT=1.5

# 网页点击“连接车”时，后端通过 SSH 登录 Nano 并启动控制和摄像头服务。
VEHICLE_SSH_HOST=192.168.31.139
VEHICLE_SSH_PORT=22
VEHICLE_SSH_USERNAME=nano1
VEHICLE_SSH_PASSWORD=123456
VEHICLE_START_SCRIPT=/home/nano1/indoor_patrol_ws/src/indoor_patrol_bringup/scripts/start_vehicle_services.sh
VEHICLE_START_TIMEOUT=8
VEHICLE_CONNECT_RETRIES=10
VEHICLE_CONNECT_RETRY_DELAY=0.8
